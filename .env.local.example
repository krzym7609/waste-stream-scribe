# =============================================================================
# WZÓR KONFIGURACJI DLA WDROŻENIA LOKALNEGO (Windows Server + Supabase self-hosted)
# =============================================================================
# Skopiuj ten plik jako .env i uzupełnij wartości z Supabase docker/.env
# Patrz: docs/WDROZENIE_LOKALNE.md
# =============================================================================

# Adres lokalnej instancji Supabase (port 8000 = Kong/API gateway)
# Zmień <ip-serwera> na realny IP lub nazwę hosta w sieci wewnętrznej
VITE_SUPABASE_URL=http://192.168.1.50:8000
SUPABASE_URL=http://192.168.1.50:8000

# Klucz publiczny (anon) — ten sam, który wygenerowałeś w Supabase docker/.env
# Bezpieczny do trzymania w przeglądarce (RLS chroni dane)
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...wklej-tu-ANON_KEY...
SUPABASE_PUBLISHABLE_KEY=eyJ...wklej-tu-ANON_KEY...

# Klucz serwisowy — pomija RLS, używany tylko po stronie serwera
# NIGDY nie wstawiaj go do zmiennych z prefiksem VITE_
SUPABASE_SERVICE_ROLE_KEY=eyJ...wklej-tu-SERVICE_ROLE_KEY...

# (Opcjonalnie) ID projektu — dla lokalnego może być dowolny string
VITE_SUPABASE_PROJECT_ID=local
SUPABASE_PROJECT_ID=local
